        "Can she play tennis? Yes, she can.",
        "Can he ride a bike? No, he can't.",
        "Can he ride a horse? No, he can't."
      ]
    },
    {
      "pattern": "Can they [verb]? Yes, they can. / No, they can't.",
      "examples": [
        "Can they play tennis? No, they can't.",
        "Can they skateboard? Yes, they can."
      ]
    },
    {
      "pattern": "Where's the [noun]? It's [preposition] the [noun].",
      "examples": [
        "Where's the skateboard? It's in front of the table.",
        "Where is my teddy bear? Is he hiding there?"
      ]
    },
    {
      "pattern": "The [noun] is [preposition] the [noun].",
      "examples": [
        "The book is behind the teddy bear.",
        "The teddy bear is on the bed.",
        "The toy box is between the bed and the chair."
      ]
    },
    {
      "pattern": "This is / It's a [consonant-noun]. / This is / It's an [vowel-noun].",
      "examples": [
        "This is an apple.",
        "It's a blue doll.",
        "I have an ice pop.",
        "She has an egg."
      ]
    }
