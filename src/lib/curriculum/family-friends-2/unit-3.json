  "grammar_patterns": [
    {
      "pattern": "I can [verb]. / I can't [verb].",
      "examples": [
        "I can skate.",
        "I can swim.",
        "I can't skateboard.",
        "I can't ride a bike."
      ]
    },
    {
      "pattern": "Can he/she [verb]? Yes, she can. / No, he can't.",
