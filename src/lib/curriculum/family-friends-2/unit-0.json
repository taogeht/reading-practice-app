  "grammar_patterns": [
    {
      "pattern": "I have [adjective] [noun].",
      "examples": [
        "I have brown hair.",
        "I have long hair.",
        "I have a little brother."
      ]
    },
    {
      "pattern": "He/She has [adjective] [noun].",
      "examples": [
        "He has green eyes.",
        "She has curly hair.",
        "He has lots of teddy bears."
      ]
    },
    {
      "pattern": "My/His/Her name's [name].",
      "examples": [
        "My name's Rosy.",
        "His name's Billy.",
        "Her name's Jasmin."
      ]
    },
    {
      "pattern": "This is my [family member].",
      "examples": [
        "This is my cousin, Tim.",
        "This is my sister.",
        "This is my friend."
      ]
    },
    {
      "pattern": "This is [name]'s [family member].",
      "examples": [
        "This is Rosy's mom.",
        "This is Rosy's dad.",
        "Tim is Rosy's cousin."
      ]
    },
    {
      "pattern": "He's/She's/I'm [number]. (age)",
      "examples": [
        "He's two.",
        "I'm seven.",
        "She's nine."
      ]
    },
    {
      "pattern": "Where's [name]? Is he/she [preposition] the [noun]?",
      "examples": [
        "Where's Billy?",
        "Is he under the bed?",
        "No, he isn't."
      ]
    },
    {
      "pattern": "How many [plural noun] are there? There are [number] [plural noun].",
      "examples": [
        "How many cars are there?",
        "There are ten cars.",
        "How many balls are there? There are five balls."
      ]
    },
    {
      "pattern": "There is [singular noun]. / There are [plural noun].",
      "examples": [
        "There is one train.",
        "There is one puzzle.",
        "There are three balls."
      ]
    },
    {
      "pattern": "What color is [noun]? It's [color].",
      "examples": [
        "What color is number 18?",
        "It's blue.",
        "What color is the car? It's red."
      ]
    },
    {
      "pattern": "Greetings.",
      "examples": [
        "Hello. How are you?",
        "I'm fine, thank you.",
        "How old are you? I'm seven.",
        "Goodbye."
      ]
    }
  ],
  "key_sentences": [
