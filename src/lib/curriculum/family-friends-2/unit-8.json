  "grammar_patterns": [
    {
      "pattern": "What time is it? It's [number] o'clock.",
      "examples": [
        "What time is it? It's seven o'clock.",
        "It's three o'clock.",
        "It's nine o'clock."
      ]
    },
    {
      "pattern": "He/She [verb-s] at [number] o'clock.",
      "examples": [
        "He gets up at six o'clock.",
        "She goes to bed at nine o'clock.",
        "He has dinner at seven o'clock.",
        "She starts work at six o'clock."
      ]
    },
    {
      "pattern": "I [activity] in the morning/afternoon/evening / at night.",
      "examples": [
        "I have breakfast in the morning.",
        "I go home at four o'clock in the afternoon.",
        "I go to bed at night."
      ]
    },
    {
      "pattern": "What do you do in the [part of day]? I [activity].",
      "examples": [
        "What do you do in the morning? I get up.",
        "What do you do in the evening? I do my homework.",
        "What do you do at night? I brush my teeth."
      ]
    },
    {
      "pattern": "What/Where/When question words.",
      "examples": [
        "What's your name?",
        "When do you have P.E.?",
        "Where do you go?",
        "When does she get up?"
      ]
    }
