      "examples": [
        "I like donkeys and horses.",
        "Everyone was happy."
      ]
    },
    {
      "pattern": "[Subject] doesn't/don't [verb] [noun] or [noun]. (or)",
      "examples": [
        "I don't like dogs or cats."
      ]
    },
    {
      "pattern": "Plurals: [noun]+s (vowel + y) / +ies (consonant + y).",
      "examples": [
        "boy -> boys, turkey -> turkeys, monkey -> monkeys",
        "family -> families, baby -> babies, party -> parties"
      ]
    }
