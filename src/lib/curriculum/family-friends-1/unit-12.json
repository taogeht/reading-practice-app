      ]
    },
    {
      "pattern": "[Name] has [food], [food], and [food].",
      "examples": [
        "Steve has eggs, bread, and tomatoes.",
        "He has grapes and ice cream.",
        "Alice has fish, rice, and carrots."
      ]
    }
  ],
  "key_sentences": [
