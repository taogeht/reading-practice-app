  "grammar_patterns": [
    {
      "pattern": "Let's [verb] [object].",
      "examples": [
        "Let's play ball!",
        "Let's find shells.",
        "Let's make sandcastles!",
        "Let's count the shells.",
        "Let's find the crabs.",
        "Let's make a sandcastle.",
        "Let's walk on the beach.",
        "Let's swim in the ocean.",
        "Let's go in a boat."
      ]
    },
    {
      "pattern": "Let's go and [verb] [noun].",
      "examples": [
        "Let's go and have fun.",
        "Let's go and play ball.",
        "Let's go and find shells."
      ]
    },
    {
      "pattern": "That's a good idea.",
      "examples": [
        "Let's play ball! That's a good idea.",
        "Let's find shells. That's a good idea."
      ]
    },
    {
      "pattern": "Don't forget your [noun].",
      "examples": [
        "Don't forget your hat.",
        "Don't forget your sunscreen.",
        "Don't forget your shovel.",
        "Don't forget your pail."
      ]
    },
    {
      "pattern": "I am at the [noun]. / We're at the [noun].",
      "examples": [
        "I am at the beach.",
        "We're at the beach.",
        "We're at the ocean."
      ]
    },
    {
      "pattern": "He/She has a/an [noun].",
      "examples": [
        "He has sunscreen.",
        "She has ice cream.",
        "He has an ice pop.",
        "He has a bat.",
        "She has a drink.",
        "He has a ball."
      ]
    },
    {
      "pattern": "I have a [noun]. / I have lots of [noun]s.",
      "examples": [
        "I have a kite.",
        "I have a frisbee.",
        "I have lots of shells.",
        "I have lots of friends."
      ]
    },
    {
      "pattern": "Here is the [noun].",
      "examples": [
        "Here is the rug.",
        "Here is the sandcastle.",
        "Here is the boat."
      ]
    },
    {
      "pattern": "How many [noun]s does a [noun] have? It has [number] [noun]s.",
      "examples": [
        "How many legs does a crab have? It has ten legs.",
        "How many shells does it have? It has five shells.",
        "How many eyes does a fish have? It has two eyes."
      ]
    },
    {
      "pattern": "Does a [noun] have [object]? Yes, it does. / No, it doesn't.",
      "examples": [
        "Does a crab have a shell? Yes, it does.",
        "Does a fish have legs? No, it doesn't.",
        "Does a bird have wings? Yes, it does."
      ]
    },
    {
      "pattern": "Can [plural subject] [verb]? Yes, they can. / No, they can't.",
      "examples": [
        "Can crabs run? Yes, they can.",
        "Can crabs fly? No, they can't.",
        "Can birds swim? Some can."
      ]
    }
