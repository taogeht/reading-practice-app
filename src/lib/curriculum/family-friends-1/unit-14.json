  "grammar_patterns": [
    {
      "pattern": "[Subject] can [verb].",
      "examples": [
        "She can draw.",
        "She can swim.",
        "He can run.",
        "I can sing.",
        "This boy can swim.",
        "This girl can run."
      ]
    },
    {
      "pattern": "[Subject] can't [verb].",
      "examples": [
        "He can't cook.",
        "She can't fly.",
        "I can't swim.",
        "It can't talk.",
        "This cat can't climb.",
        "This dog can't fly."
      ]
    },
    {
      "pattern": "Can [subject] [verb]?",
      "examples": [
        "Can she draw?",
        "Can he run?",
        "Can it fly?",
        "Can she sing?",
        "Can he climb?"
      ]
    },
    {
      "pattern": "Yes, [subject] can. / No, [subject] can't.",
      "examples": [
        "Can Anna run? Yes, she can.",
        "Can Jim swim? No, he can't.",
        "Can it fly? No, it can't.",
        "Can she draw? Yes, she can."
      ]
    },
    {
      "pattern": "What can you do? I can [verb].",
      "examples": [
        "What can you do? I can sing.",
        "What can you do? I can dance and draw.",
        "What can you do? I can run.",
        "What can you do? I can read."
      ]
    },
    {
      "pattern": "A [animal] can/can't [verb] [object].",
      "examples": [
        "A giraffe can't climb trees.",
        "A monkey can climb trees.",
        "A snake can't walk.",
        "A seal can't fly.",
        "A bird can fly."
      ]
    },
    {
      "pattern": "A [animal] cannot [verb]. (long form of can't)",
      "examples": [
        "A giraffe cannot swim.",
        "A monkey cannot fly.",
        "A snake cannot run.",
        "A seal cannot talk."
      ]
    },
    {
      "pattern": "[Subject] can [verb] and [subject] can [verb].",
      "examples": [
        "They can swim and they can fly.",
        "She can sing and she can dance.",
        "I can read and I can write."
      ]
    },
    {
      "pattern": "[Subject] can [verb], but [subject] cannot [verb].",
      "examples": [
        "They can swim, but they cannot fly.",
        "I can sing, but I cannot dance.",
        "He can run, but he cannot swim."
      ]
    },
    {
      "pattern": "It is [adjective]. It has [adjective] [noun].",
      "examples": [
        "It is pink. It has yellow eyes.",
        "It is tall. It has long legs.",
        "It is small. It has a long neck."
      ]
    },
    {
      "pattern": "[Animal]s like [noun].",
      "examples": [
        "Flamingos like water.",
        "Monkeys like trees.",
        "Birds like the sky."
      ]
    }
  ],
